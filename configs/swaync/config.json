{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "control-center-width": 300,
  "fit-to-screen": true,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "notification-body-image-height": 140,
  "notification-body-image-width": 240,
  "hide-on-action": true,

  "widgets": [
    "buttons-grid#power",
    "volume",
    "buttons-grid#audio-routes",
    "buttons-grid#toggles",
    "dnd",
    "title",
    "notifications"
  ],

  "widget-config": {
    "buttons-grid#power": {
      "actions": [
        {
          "label": "",
          "text": "Power Menu",
          "command": "~/.config/hyprdora/scripts/sys-power.sh"
        }
      ]
    },

    "volume": {
      "label": " "
    },

    "buttons-grid#audio-routes": {
      "actions": [
        {
          "label": "  Speakers",
          "command": "swaync-client -cp && alacritty --class sysaudio -e wiremix -v output"
        },
        {
          "label": "  Microphone",
          "command": "swaync-client -cp && alacritty --class sysaudio -e wiremix -v input"
        }
      ]
    },

    "buttons-grid#toggles": {
      "actions": [
        {
          "label": "[ Wi-Fi ]",
          "command": "swaync-client -cp && alacritty --class systui -e nmtui"
        },
        {
          "label": "[ Bluetooth ]",
          "command": "swaync-client -cp && alacritty --class systui -e bluetoothctl"
        },
        {
          "label": "[ Power Mode ]",
          "command": "~/.config/hyprdora/scripts/power-profiles.sh"
        },
        {
          "label": "[ Displays ]",
          "command": "swaync-client -cp && nwg-displays"
        }
      ]
    },

    "dnd": {
      "text": "Do Not Disturb"
    },

    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear All"
    },

    "notifications": {
      "display": ["core"]
    }
  }
}
